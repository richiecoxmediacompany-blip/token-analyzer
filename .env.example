# Solana Token Analyzer - Environment Variables
# Copy this file to .env.local and fill in your API keys

# Helius RPC (https://helius.dev) - Required for on-chain data
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API (https://birdeye.so) - Required for price/volume data
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Solscan API (https://solscan.io) - Optional, enhances holder data
SOLSCAN_API_KEY=your_solscan_api_key_here

# Twitter Bearer Token - Optional, for social signals
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Base URL for the app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
